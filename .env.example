# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then copy these values from
# Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "true" to use in-memory seed data (no Supabase required).
# Set to "false" (or remove) to use live Supabase database.
# If Supabase env vars are missing, demo mode activates automatically.
VITE_DEMO_MODE=true

# ─── EmailJS (optional — for sending application invitations) ─────────────────
# Sign up at https://emailjs.com, create a service + template, then fill these.
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ─── Setup Steps ──────────────────────────────────────────────────────────────
# 1. Create Supabase project
# 2. Run supabase/migrations/001_initial_schema.sql in SQL Editor
# 3. Run supabase/migrations/002_auth_and_fixes.sql in SQL Editor
# 4. Run supabase/seed.sql to populate initial users + company codes
# 5. In Supabase Auth → Users, create auth accounts for each staff member
#    (use same emails: jordan@nzinga.co, marcus@nzinga.co, etc.)
# 6. Copy each auth user's UUID and run:
#    UPDATE users SET auth_uid = '<uuid>' WHERE email = '<email>';
# 7. Create a private storage bucket named "documents"
# 8. Copy the project URL and anon key into this file
# 9. Set VITE_DEMO_MODE=false
# 10. Run: npm run dev
